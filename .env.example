# ============================================================
# EXPENSE TRACKER — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Supabase Project URL (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (safe to expose — RLS handles security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  NEVER add SUPABASE_SERVICE_ROLE_KEY here.
# ⚠️  NEVER prefix sensitive keys with NEXT_PUBLIC_.
# ⚠️  This app only needs the anon key.
